# Shopify App credentials (obtenidos al crear la app en Partners)
SHOPIFY_API_KEY=tu_api_key
SHOPIFY_API_SECRET=tu_api_secret

# URL pública para OAuth. En local usa ngrok y pega la URL aquí
# Ejemplo: https://abc123.ngrok-free.app
HOST=https://tu-ngrok-url.ngrok-free.app

# Puerto local
PORT=3000

# API version de Shopify
SHOPIFY_API_VERSION=2024-04
